rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /siteContent/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shows/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /youtubeVideos/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /discography/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
